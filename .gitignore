# PostgreSQL Extension .gitignore for pg_uuid_v8

# =============================================================================
# Build artifacts
# =============================================================================
*.o
*.so
*.bc
*.a
*.pc

# PostgreSQL extension build outputs
pg_uuid_v8.so
pg_uuid_v8.o
pg_uuid_v8.bc
libpg_uuid_v8.a
libpg_uuid_v8.pc

# =============================================================================
# PostgreSQL test artifacts
# =============================================================================
results/
regression.diffs
regression.out
tmp_check/
tmp_check_iso/
log/
output_iso/

# =============================================================================
# Environment and credentials
# =============================================================================
.env
.pgpass
*.pgpass

# =============================================================================
# Articles and documentation (for separate publication)
# =============================================================================
articles/

# Exclude all markdown files except essential ones
*.md
!README.md
!LICENSE.md

# =============================================================================
# Memory Bank (development artifacts)
# =============================================================================
memory-bank/
.claude/

# =============================================================================
# Test files (optional - keep only official regression tests)
# =============================================================================
test_*.sql
!sql/pg_uuid_v8_test.sql

# =============================================================================
# IDE and editor files
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# =============================================================================
# OS specific
# =============================================================================
Thumbs.db
*.tmp
*.bak

# =============================================================================
# Version control
# =============================================================================
.git/

# =============================================================================
# Temporary and cache files
# =============================================================================
*.cache
*.log
*.tmp
core.*

# =============================================================================
# PostgreSQL specific
# =============================================================================
*.pid
*.lock

# =============================================================================
# Documentation build artifacts
# =============================================================================
*.aux
*.fdb_latexmk
*.fls
*.synctex.gz

# =============================================================================
# Backup files
# =============================================================================
*~
*.orig
*.rej

# =============================================================================
# Archive files
# =============================================================================
*.tar
*.tar.gz
*.zip
*.rar

# =============================================================================
# Keep these essential files
# =============================================================================
# !pg_uuid_v8.c
# !pg_uuid_v8.control
# !pg_uuid_v8--1.0.sql
# !Makefile
# !README.md
# !CLAUDE.md
# !sql/pg_uuid_v8_test.sql
# !expected/pg_uuid_v8_test.outCLAUDE.md
